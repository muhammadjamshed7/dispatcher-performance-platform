NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME="Dispatcher Performance Platform"

# Vercel/serverless (IPv4): Supabase Transaction pooler for DATABASE_URL (port 6543).
# Supabase Dashboard → Connect → copy the Transaction pooler URI.
# Example:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Session pooler for DIRECT_URL (port 5432) — migrations and bootstrap.
# DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres
DATABASE_URL=
DIRECT_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alias if your Supabase dashboard labels the anon key as publishable:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

SESSION_COOKIE_NAME=
AUTH_REDIRECT_URL=

APP_ENCRYPTION_KEY=
CSRF_SECRET=

REPORT_EXPORT_MAX_ROWS=
REPORT_EXPORT_STORAGE_BUCKET=

DEFAULT_TIMEZONE=
DEFAULT_CURRENCY=

RESEND_API_KEY=
FROM_EMAIL=

SENTRY_DSN=
LOG_LEVEL=
