NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME="Dispatcher Performance Platform"

# Vercel/serverless (IPv4): use Supabase Transaction pooler for DATABASE_URL.
# Supabase Dashboard → Connect → ORMs → copy "Transaction pooler" URI (port 6543).
# Example shape:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Local migrations / bootstrap: use DIRECT_URL (direct connection, IPv6).
# DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=
DIRECT_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alias if your Supabase dashboard labels the anon key as publishable:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

SESSION_COOKIE_NAME=
AUTH_REDIRECT_URL=

APP_ENCRYPTION_KEY=
CSRF_SECRET=

REPORT_EXPORT_MAX_ROWS=
REPORT_EXPORT_STORAGE_BUCKET=

DEFAULT_TIMEZONE=
DEFAULT_CURRENCY=

# Comma-separated bootstrap emails (server-only seed script).
INITIAL_ADMIN_EMAILS="admin1@example.com"
INITIAL_TEAM_LEAD_EMAILS="teamlead@example.com"
ENABLE_DEMO_DATA="false"
BOOTSTRAP_ADMIN_PASSWORD="ChangeMe123!"

RESEND_API_KEY=
FROM_EMAIL=

SENTRY_DSN=
LOG_LEVEL=
