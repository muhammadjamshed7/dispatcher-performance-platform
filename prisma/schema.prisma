generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEAM_LEAD
  DISPATCHER
}

enum UserStatus {
  ACTIVE
  PENDING_APPROVAL
  INACTIVE
  INVITED
}

enum TeamStatus {
  ACTIVE
  INACTIVE
}

enum CarrierStatus {
  ACTIVE
  INACTIVE
}

enum LoadActivityStatus {
  DELIVERED
  CANCELLED
  NOT_BOOKED
  NOT_WORKING
}

enum TruckType {
  DRY_VAN
  REEFER
  FLATBED
  BOX_TRUCK
  HOTSHOT
  POWER_ONLY
  CARGO_VAN
}

enum RegistrationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportExportStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ActivityApprovalStatus {
  APPROVED
  PENDING_TEAM_LEAD_APPROVAL
  PENDING_ADMIN_APPROVAL
  REJECTED
}

enum ActivityApprovalType {
  NEW_ACTIVITY
  EDIT_ACTIVITY
}

enum NotificationStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  ADMIN_APPROVAL_REQUIRED
  TEAM_LEAD_APPROVAL_REQUIRED
  COMPLETED
}

enum InvoiceType {
  DISPATCHER_PAYABLE
  CARRIER_RECEIVABLE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum InvoicePaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  CHECK
  OTHER
}

enum AuditAction {
  USER_APPROVED
  USER_MANUALLY_CREATED
  USER_PASSWORD_RESET
  USER_PASSWORD_CHANGED
  USER_REJECTED
  USER_ROLE_ASSIGNED
  USER_TEAM_ASSIGNED
  USER_ACTIVATED
  USER_DEACTIVATED
  USER_LOGGED_IN
  USER_LOGGED_OUT
  USER_LOGIN_FAILED
  TEAM_CREATED
  TEAM_UPDATED
  TEAM_ACTIVATED
  TEAM_DEACTIVATED
  TEAM_LEAD_CREATED
  TEAM_LEAD_ASSIGNED
  DISPATCHER_CREATED
  DISPATCHER_UPDATED
  DISPATCHER_REACTIVATED
  DISPATCHER_DEACTIVATED
  CARRIER_CREATED
  CARRIER_UPDATED
  CARRIER_ACTIVATED
  CARRIER_DEACTIVATED
  CARRIER_REASSIGNED
  CARRIER_EXPORTED
  ACTIVITY_CREATED
  ACTIVITY_UPDATED
  ACTIVITY_SUBMITTED
  ACTIVITY_EDIT_REQUEST_SUBMITTED
  ACTIVITY_APPROVED_BY_TEAM_LEAD
  ACTIVITY_APPROVED_BY_ADMIN
  ACTIVITY_REJECTED
  ACTIVITY_CHANGES_REQUESTED
  ACTIVITY_PENDING_UPDATED
  ACTIVITY_EXPORTED
  SETTINGS_UPDATED
  SETTINGS_DISPATCH_FEE_RULES_UPDATED
  SETTINGS_TRUCK_TYPES_UPDATED
  SETTINGS_STATUS_REASONS_UPDATED
  SETTINGS_DIRECT_APPROVAL_UPDATED
  NOTIFICATION_READ
  NOTIFICATION_MARK_ALL_READ
  REPORT_VIEWED
  REPORT_EXPORTED
  FINANCE_VIEWED
  FINANCE_EXPORTED
  AUDIT_LOGS_EXPORTED
  INVOICE_GENERATED
  INVOICE_UPDATED
  INVOICE_PAYMENT_RECORDED
  INVOICE_MARKED_PAID
  INVOICE_CANCELLED
  INVOICE_EXPORTED
  INVOICE_VIEWED
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  timezone  String    @default("America/Chicago")
  currency  String    @default("USD")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users                User[]
  teams                Team[]
  dispatchers          Dispatcher[]
  carriers             Carrier[]
  dailyActivities      DailyActivity[]
  dailySubmissions     DailySubmission[]
  statusReasons        StatusReason[]
  settings             OrganizationSettings?
  registrationRequests RegistrationRequest[]
  auditLogs            AuditLog[]
  reportExports        ReportExport[]
  carrierAssignments   CarrierAssignmentHistory[]
  activityEditRequests ActivityEditRequest[]
  notifications        Notification[]
  invoices             Invoice[]
  invoicePayments      InvoicePayment[]

  @@index([deletedAt])
}

model User {
  id             String     @id @default(cuid())
  organizationId String
  supabaseUserId String?    @unique
  email          String
  fullName       String
  phoneNumber    String?
  role           UserRole
  status         UserStatus @default(PENDING_APPROVAL)
  teamId         String?
  lastLoginAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  organization       Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team               Team?                      @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)
  ledTeams           Team[]                     @relation("TeamLead")
  dispatcher         Dispatcher?
  auditLogs          AuditLog[]                 @relation("AuditActor")
  reviewedRequests   RegistrationRequest[]      @relation("ReviewedBy")
  reportExports      ReportExport[]
  carrierAssignments CarrierAssignmentHistory[] @relation("AssignmentActor")
  notifications      Notification[]             @relation("NotificationRecipient")
  invoicesCreated    Invoice[]                  @relation("InvoiceCreatedBy")
  invoicesUpdated    Invoice[]                  @relation("InvoiceUpdatedBy")
  invoicePayments    InvoicePayment[]           @relation("InvoicePaymentRecordedBy")

  editRequestsSubmitted        ActivityEditRequest[] @relation("EditRequestSubmittedBy")
  editRequestsEdited           ActivityEditRequest[] @relation("EditRequestEditedBy")
  editRequestsTeamLeadApproved ActivityEditRequest[] @relation("EditRequestTeamLeadApprovedBy")
  editRequestsAdminApproved    ActivityEditRequest[] @relation("EditRequestAdminApprovedBy")
  editRequestsRejected         ActivityEditRequest[] @relation("EditRequestRejectedBy")

  @@unique([organizationId, email])
  @@index([organizationId, role, status])
  @@index([teamId])
  @@index([deletedAt])
}

model Team {
  id             String     @id @default(cuid())
  organizationId String
  name           String
  teamLeadUserId String?
  status         TeamStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  organization         Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teamLead             User?                      @relation("TeamLead", fields: [teamLeadUserId], references: [id], onDelete: SetNull)
  members              User[]                     @relation("TeamMembers")
  dispatchers          Dispatcher[]
  carriers             Carrier[]
  dailyActivities      DailyActivity[]
  dailySubmissions     DailySubmission[]
  invoices             Invoice[]
  invoiceItems         InvoiceItem[]
  assignmentHistory    CarrierAssignmentHistory[]
  activityEditRequests ActivityEditRequest[]

  @@unique([organizationId, name])
  @@index([organizationId, status])
  @@index([deletedAt])
}

model Dispatcher {
  id             String     @id @default(cuid())
  organizationId String
  userId         String     @unique
  teamId         String
  status         TeamStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  organization         Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  team                 Team                       @relation(fields: [teamId], references: [id], onDelete: Restrict)
  carriers             Carrier[]
  dailyActivities      DailyActivity[]
  dailySubmissions     DailySubmission[]
  assignmentHistory    CarrierAssignmentHistory[]
  activityEditRequests ActivityEditRequest[]
  invoices             Invoice[]
  invoiceItems         InvoiceItem[]

  @@index([organizationId, teamId, status])
  @@index([deletedAt])
}

model Carrier {
  id                    String        @id @default(cuid())
  organizationId        String
  carrierName           String
  driverName            String
  mcNumber              String
  truckType             TruckType
  teamId                String
  dispatcherId          String?
  dispatchFeePercentage Decimal       @db.Decimal(5, 2)
  status                CarrierStatus @default(ACTIVE)
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  deletedAt             DateTime?

  organization      Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team              Team                       @relation(fields: [teamId], references: [id], onDelete: Restrict)
  dispatcher        Dispatcher?                @relation(fields: [dispatcherId], references: [id], onDelete: SetNull)
  dailyActivities   DailyActivity[]
  assignmentHistory CarrierAssignmentHistory[]
  invoices          Invoice[]
  invoiceItems      InvoiceItem[]

  @@unique([organizationId, mcNumber])
  @@index([organizationId, teamId, status])
  @@index([dispatcherId])
  @@index([deletedAt])
}

model CarrierAssignmentHistory {
  id                     String    @id @default(cuid())
  organizationId         String
  carrierId              String
  teamId                 String
  dispatcherId           String?
  teamNameSnapshot       String
  dispatcherNameSnapshot String?
  assignedAt             DateTime  @default(now())
  unassignedAt           DateTime?
  assignedByUserId       String
  notes                  String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  carrier      Carrier      @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Restrict)
  dispatcher   Dispatcher?  @relation(fields: [dispatcherId], references: [id], onDelete: SetNull)
  assignedBy   User         @relation("AssignmentActor", fields: [assignedByUserId], references: [id], onDelete: Restrict)

  @@index([carrierId, assignedAt])
  @@index([organizationId])
}

model DailyActivity {
  id                            String                 @id @default(cuid())
  organizationId                String
  activityDate                  DateTime               @db.Date
  carrierId                     String
  dispatcherId                  String
  teamId                        String
  status                        LoadActivityStatus
  carrierNameSnapshot           String
  driverNameSnapshot            String
  dispatcherNameSnapshot        String
  teamNameSnapshot              String
  truckTypeSnapshot             TruckType
  dispatchFeePercentageSnapshot Decimal                @db.Decimal(5, 2)
  origin                        String?
  destination                   String?
  totalMiles                    Decimal?               @db.Decimal(10, 2)
  loadAmount                    Decimal?               @db.Decimal(12, 2)
  ratePerMile                   Decimal?               @db.Decimal(10, 4)
  dispatchFee                   Decimal?               @db.Decimal(12, 2)
  reason                        String?
  notes                         String?
  approvalStatus                ActivityApprovalStatus @default(APPROVED)
  submittedById                 String?
  teamLeadApprovedById          String?
  adminApprovedById             String?
  rejectedById                  String?
  rejectionReason               String?
  approvalNotes                 String?
  approvalType                  ActivityApprovalType   @default(NEW_ACTIVITY)
  submittedAt                   DateTime?
  teamLeadApprovedAt            DateTime?
  adminApprovedAt               DateTime?
  rejectedAt                    DateTime?
  createdAt                     DateTime               @default(now())
  updatedAt                     DateTime               @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  carrier      Carrier               @relation(fields: [carrierId], references: [id], onDelete: Restrict)
  dispatcher   Dispatcher            @relation(fields: [dispatcherId], references: [id], onDelete: Restrict)
  team         Team                  @relation(fields: [teamId], references: [id], onDelete: Restrict)
  editRequests ActivityEditRequest[] @relation("OriginalActivity")
  invoiceItems InvoiceItem[]

  @@index([carrierId, activityDate])
  @@index([organizationId, activityDate])
  @@index([dispatcherId, activityDate])
  @@index([teamId, activityDate])
  @@index([status])
  @@index([organizationId, approvalStatus])
  @@index([teamId, approvalStatus])
}

model DailySubmission {
  id             String   @id @default(cuid())
  organizationId String
  dispatcherId   String
  teamId         String
  submissionDate DateTime @db.Date
  submittedAt    DateTime @default(now())
  carrierCount   Int      @default(0)
  activityCount  Int      @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dispatcher   Dispatcher   @relation(fields: [dispatcherId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@unique([dispatcherId, submissionDate])
  @@index([organizationId, submissionDate])
  @@index([teamId, submissionDate])
}

model StatusReason {
  id             String   @id @default(cuid())
  organizationId String
  label          String
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, label])
  @@index([organizationId, isActive])
}

model OrganizationSettings {
  id                        String      @id @default(cuid())
  organizationId            String      @unique
  dispatchFeeMethod         String      @default("percentage")
  defaultDispatchFeePercent Decimal     @default(12) @db.Decimal(5, 2)
  minimumDispatchFee        Decimal     @default(0) @db.Decimal(12, 2)
  roundToNearestDollar      Boolean     @default(true)
  allowedTruckTypes         TruckType[]
  timezone                  String      @default("America/Chicago")
  csvIncludeHeaders         Boolean     @default(true)
  csvDateFormat             String      @default("yyyy-MM-dd")
  csvMaxRows                Int         @default(10000)
  csvFileNamePrefix         String      @default("dpp-report")
  directAdminApprovalMode   Boolean     @default(false)
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model RegistrationRequest {
  id                String                    @id @default(cuid())
  organizationId    String
  fullName          String
  email             String
  phoneNumber       String
  requestedRole     UserRole                  @default(DISPATCHER)
  preferredTeamId   String?
  preferredTeamName String?
  notes             String?
  status            RegistrationRequestStatus @default(PENDING)
  submittedAt       DateTime                  @default(now())
  reviewedAt        DateTime?
  reviewedByUserId  String?
  rejectionReason   String?
  assignedTeamId    String?
  assignedRole      UserRole?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviewedBy   User?        @relation("ReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, submittedAt])
  @@index([email])
}

model ActivityEditRequest {
  id                   String                 @id @default(cuid())
  organizationId       String
  originalActivityId   String
  teamId               String
  dispatcherId         String
  approvalStatus       ActivityApprovalStatus
  proposedChanges      Json
  previousData         Json
  submittedById        String
  editedById           String
  teamLeadApprovedById String?
  adminApprovedById    String?
  rejectedById         String?
  rejectionReason      String?
  approvalNotes        String?
  submittedAt          DateTime               @default(now())
  editedAt             DateTime               @default(now())
  teamLeadApprovedAt   DateTime?
  adminApprovedAt      DateTime?
  rejectedAt           DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  originalActivity   DailyActivity @relation("OriginalActivity", fields: [originalActivityId], references: [id], onDelete: Cascade)
  team               Team          @relation(fields: [teamId], references: [id], onDelete: Restrict)
  dispatcher         Dispatcher    @relation(fields: [dispatcherId], references: [id], onDelete: Restrict)
  submittedBy        User          @relation("EditRequestSubmittedBy", fields: [submittedById], references: [id], onDelete: Restrict)
  editedBy           User          @relation("EditRequestEditedBy", fields: [editedById], references: [id], onDelete: Restrict)
  teamLeadApprovedBy User?         @relation("EditRequestTeamLeadApprovedBy", fields: [teamLeadApprovedById], references: [id], onDelete: SetNull)
  adminApprovedBy    User?         @relation("EditRequestAdminApprovedBy", fields: [adminApprovedById], references: [id], onDelete: SetNull)
  rejectedBy         User?         @relation("EditRequestRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)

  @@index([organizationId, approvalStatus])
  @@index([originalActivityId, approvalStatus])
  @@index([teamId, approvalStatus])
  @@index([dispatcherId, approvalStatus])
}

model Notification {
  id                 String             @id @default(cuid())
  organizationId     String
  recipientUserId    String
  title              String
  message            String
  notificationStatus NotificationStatus
  activityId         String?
  editRequestId      String?
  metadata           Json?
  readAt             DateTime?
  createdAt          DateTime           @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipient    User         @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, readAt, createdAt])
  @@index([organizationId, createdAt])
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  invoiceNumber  String
  invoiceType    InvoiceType
  invoiceStatus  InvoiceStatus @default(ISSUED)
  paymentStatus  PaymentStatus @default(UNPAID)
  dispatcherId   String?
  carrierId      String?
  teamId         String?
  periodStart    DateTime      @db.Date
  periodEnd      DateTime      @db.Date
  issueDate      DateTime      @db.Date
  dueDate        DateTime      @db.Date
  subtotalAmount Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal       @default(0) @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(12, 2)
  pendingAmount  Decimal       @default(0) @db.Decimal(12, 2)
  notes          String?
  createdById    String
  updatedById    String?
  paidAt         DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dispatcher   Dispatcher?      @relation(fields: [dispatcherId], references: [id], onDelete: SetNull)
  carrier      Carrier?         @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  team         Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdBy    User             @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy    User?            @relation("InvoiceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  items        InvoiceItem[]
  payments     InvoicePayment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, invoiceType])
  @@index([organizationId, invoiceStatus])
  @@index([organizationId, paymentStatus])
  @@index([dispatcherId])
  @@index([carrierId])
  @@index([teamId])
  @@index([periodStart, periodEnd])
  @@index([deletedAt])
}

model InvoiceItem {
  id              String             @id @default(cuid())
  invoiceId       String
  dailyActivityId String?
  activityDate    DateTime           @db.Date
  carrierId       String
  dispatcherId    String
  teamId          String
  status          LoadActivityStatus
  origin          String?
  destination     String?
  totalMiles      Decimal?           @db.Decimal(10, 2)
  loadAmount      Decimal?           @db.Decimal(12, 2)
  dispatchFee     Decimal?           @db.Decimal(12, 2)
  ratePerMile     Decimal?           @db.Decimal(10, 4)
  itemDescription String?
  amount          Decimal            @default(0) @db.Decimal(12, 2)
  createdAt       DateTime           @default(now())

  invoice       Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  dailyActivity DailyActivity? @relation(fields: [dailyActivityId], references: [id], onDelete: SetNull)
  carrier       Carrier        @relation(fields: [carrierId], references: [id], onDelete: Restrict)
  dispatcher    Dispatcher     @relation(fields: [dispatcherId], references: [id], onDelete: Restrict)
  team          Team           @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([dailyActivityId])
  @@index([carrierId])
  @@index([dispatcherId])
  @@index([teamId])
}

model InvoicePayment {
  id               String               @id @default(cuid())
  invoiceId        String
  organizationId   String
  paymentAmount    Decimal              @db.Decimal(12, 2)
  paymentDate      DateTime             @db.Date
  paymentMethod    InvoicePaymentMethod
  paymentReference String?
  notes            String?
  recordedById     String
  createdAt        DateTime             @default(now())

  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recordedBy   User         @relation("InvoicePaymentRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([organizationId])
  @@index([recordedById])
  @@index([paymentDate])
}

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String
  actorUserId    String?
  action         AuditAction
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
}

model ReportExport {
  id             String             @id @default(cuid())
  organizationId String
  requestedById  String
  reportType     String
  period         String
  filters        Json               @default("{}")
  status         ReportExportStatus @default(PENDING)
  fileName       String?
  rowCount       Int?
  errorMessage   String?
  createdAt      DateTime           @default(now())
  completedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedBy  User         @relation(fields: [requestedById], references: [id], onDelete: Restrict)

  @@index([organizationId, createdAt])
}
